# Discord bot — environment variables.
# Copy to "bot/.env" and fill in. These can be the SAME values you used for the
# website (the bot reuses the same Discord application, token, and server).

# Bot token (Developer Portal -> Your App -> Bot -> Reset Token)
DISCORD_BOT_TOKEN=

# Application (client) ID (Developer Portal -> Your App -> General Information)
DISCORD_CLIENT_ID=

# Your Discord server (guild) ID
DISCORD_GUILD_ID=

# OPTIONAL — channel IDs (right-click a channel -> Copy Channel ID, Developer Mode on)
# Where to greet new members. Leave blank to disable welcome messages.
WELCOME_CHANNEL_ID=
# Where to log when a member's site access changes. Leave blank to disable.
LOG_CHANNEL_ID=

# OPTIONAL — your site URL, used in messages/links. Defaults to localhost.
SITE_URL=http://localhost:3001

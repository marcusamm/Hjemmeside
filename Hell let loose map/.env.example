# ============================================================
# Copy this file to .env and fill in your values.
# On Replit, use the Secrets tab instead of this file.
# ============================================================

# Your Hell Let Loose server
HLL_SERVER_HOST=45.143.199.235
HLL_GAME_PORT=10711
HLL_QUERY_PORT=28601

# CRCON web panel URL (no trailing slash)
CRCON_URL=http://objectivefirst.ddns.net:8010

# CRCON login — use your CRCON web admin username/password
# (the account you use at /admin, NOT your in-game name)
CRCON_USERNAME=your-crcon-admin-username
CRCON_PASSWORD=your-crcon-admin-password

# Optional: Django API token instead of username/password
# Create one in CRCON admin → Django API Keys
# Only used if CRCON_USERNAME / CRCON_PASSWORD are not set
CRCON_API_TOKEN=

# How often to poll CRCON (milliseconds)
CRCON_POLL_MS=5000
CRCON_PLAYER_POLL_MS=2000

# Port the web server listens on
PORT=5000
